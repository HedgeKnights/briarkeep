font-size = 13
font-family = "JetBrains Mono Nerd Font"
cursor-style = block

# Enables font ligatures for JetBrains Mono
font-feature = "calt"
font-feature = "liga"

# Removes the native OS title bar for a flush look
window-decoration = false

# Adds a small internal margin (padding)
window-padding-x = 10
window-padding-y = 10

# Prevents the window from snapping to character grid sizes 
# (removes those weird gaps at the edges when resizing)
window-step-resize = true
# Makes the cursor blink with a smooth fade
cursor-style-blink = true
# Hides the mouse cursor immediately when you start typing
mouse-hide-while-typing = true
# Quick copy-on-select (standard in many pro terminals)
copy-on-select = true
# Focuses the window when you hover over it (optional, but very "Linux-pro")
focus-follows-mouse = true
# Adds a subtle transparency (0.0 to 1.0)
background-opacity = 0.95
# Blurs the background behind the window
background-blur = 20
# Increase the amount of history saved in the buffer
scrollback-limit = 100000
# Clickable URLs (hold Cmd/Ctrl + click to open)
link-url = true
