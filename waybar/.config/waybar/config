{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 4,
  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["pulseaudio", "network", "cpu", "memory", "tray"],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate"
  },

"clock": {
  "format": "{:%I:%M %p}",
  "format-alt": "{:%a %b %d %I:%M %p}",
  "tooltip-format": "{:%A, %B %d, %Y %I:%M:%S %p}",
  "on-click-right": "mode"
},
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol"
  }
}
